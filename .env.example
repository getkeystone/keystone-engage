# Keystone Engage configuration
# Copy to .env and adjust for your environment

# Ollama endpoint (set to your own inference host)
KEYSTONE_OLLAMA_BASE_URL=http://<ollama-host>:11434
KEYSTONE_OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
KEYSTONE_OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG parameters (set operational values per-environment; not published here)
KEYSTONE_RETRIEVAL_TOP_K=<int>
KEYSTONE_CONFIDENCE_THRESHOLD=<0.0-1.0>

# Corpus directory
KEYSTONE_CORPUS_DIR=data/corpus

# Environment
KEYSTONE_ENV=development

# OTel (set to your collector endpoint when available)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://<otel-host>:4317

# PostgreSQL + pgvector (empty = in-memory fallback)
# KEYSTONE_DATABASE_URL=postgresql://keystone:PASSWORD@<db-host>:5432/keystone_engage
