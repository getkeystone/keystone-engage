# Keystone Engage configuration
# Copy to .env and adjust for your environment

# Ollama endpoint (ForgePrime via Tailscale)
KEYSTONE_OLLAMA_BASE_URL=http://100.90.230.74:11434
KEYSTONE_OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
KEYSTONE_OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG parameters
KEYSTONE_RETRIEVAL_TOP_K=5
KEYSTONE_CONFIDENCE_THRESHOLD=0.55

# Corpus directory
KEYSTONE_CORPUS_DIR=data/corpus

# Environment
KEYSTONE_ENV=development

# OTel (set to SolsticeNode endpoint when available)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://solsticenode.tailnet:4317

# PostgreSQL + pgvector on AnchorNode (empty = in-memory fallback)
# KEYSTONE_DATABASE_URL=postgresql://keystone:PASSWORD@100.70.20.65:5432/keystone_engage
